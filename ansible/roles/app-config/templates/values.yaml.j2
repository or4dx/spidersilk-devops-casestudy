# Generated by Ansible — do not edit directly.
# Source: ansible/roles/app-config/templates/values.yaml.j2
# Re-generate: ansible-playbook playbooks/deploy.yaml --tags config --ask-vault-pass

replicaCount: {{ replica_count }}

image:
  repository: or4dx/csv-processor
  tag: "{{ image_tag }}"
  pullPolicy: Always

config:
  port:        "{{ app_port }}"
  logLevel:    {{ log_level }}
  awsRegion:   {{ aws_region }}
  s3Bucket:    {{ s3_bucket }}
  templateDir: /templates

autoscaling:
  enabled:                          {{ autoscaling_enabled | lower }}
  minReplicas:                      {{ autoscaling_min_replicas }}
  maxReplicas:                      {{ autoscaling_max_replicas }}
  targetCPUUtilizationPercentage:   60
  targetMemoryUtilizationPercentage: 80

serviceAccount:
  irsaRoleArn: "{{ irsa_role_arn | default('') }}"
